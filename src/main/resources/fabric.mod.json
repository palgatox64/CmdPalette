{
  "schemaVersion": 1,
  "id": "cmdpalette",
  "version": "${version}",

  "name": "CmdPalette",
  "description": "A high-efficiency command palette for Minecraft. Streamlines command execution and navigation through a responsive fuzzy-search interface.",
  "authors": [],
  "contact": {},

  "license": "MIT",
  "icon": "assets/cmdpalette/icon.png",

  "environment": "client",
  "entrypoints": {
    "fabric-datagen": ["me.palgato.cmdpalette.client.CmdPaletteDataGenerator"],
    "client": ["me.palgato.cmdpalette.client.CmdPaletteClient"],
    "main": ["me.palgato.cmdpalette.CmdPalette"]
  },

  "mixins": [
    "cmdpalette.mixins.json"
    ,{
      "config": "cmdpalette.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
